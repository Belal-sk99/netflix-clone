<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Netflix Stranger Things</title>
  <style>
   
  </style>
  <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
  <link rel="stylesheet" href="styles/style.css">
</head>
<body>
  <section class="hero">
    <div class="top-line"></div>

    <nav class="navbar">
      <div class="nav-left">
        <div class="logo">NETFLIX</div>

        <ul class="nav-links">
          <li><a href="#">Home</a></li>
          <li><a href="#" class="active">TV Programmes</a></li>
          <li><a href="#">Films</a></li>
          <li><a href="#">Originals</a></li>
          <li><a href="#">Recently Added</a></li>
          <li><a href="#">My List</a></li>
        </ul>
      </div>

      <div class="nav-right">
        <div class="search"><i class="fa-solid fa-magnifying-glass"></i> </div>
        <div class="profile">
          <img src="https://i.pravatar.cc/40?img=12" alt="profile">
        </div>
      </div>
    </nav>

    <div class="content">
      <h1 class="title">Stranger Things</h1>

      <div class="meta">
        <span class="match">97% Match</span>
        <span>2017</span>
        <span>16+</span>
        <span>5 Seasons</span>
        <span>Netflix Original, Teen Program</span>
      </div>

      <p class="description">
        When a young boy vanishes, a small town uncovers a mystery involving secret experiments, terrifying supernatural forces and one strange little girl.
      </p>

      <div class="actions">
        <button class="watch-btn"><i class="fa-solid fa-play"></i>  WATCH</button>
        <button class="circle-btn"><i class="fa-solid fa-plus"></i> </button>
        <button class="circle-btn"><i class="fa-solid fa-share"></i> </button>
        <button class="circle-btn"><i class="fa-solid fa-thumbs-up"></i> </button>
        <button class="circle-btn"><i class="fa-solid fa-thumbs-down"></i> </button>
      </div>
    </div>
  </section>
